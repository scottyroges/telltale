// Better Auth CLI workflow (`npx @better-auth/cli generate`):
// The CLI requires @prisma/client types, which we no longer generate.
// To run it, temporarily:
//   1. Add:  generator client { provider = "prisma-client-js" }
//   2. Remove `import "server-only"` from src/server/auth.ts and src/lib/db.ts
//   3. Run:  npx prisma generate
//   4. Run:  npx @better-auth/cli generate
//   5. Undo steps 1 and 2, then run `npx prisma generate` again

generator kysely {
  provider     = "prisma-kysely"
  output       = "../src/db"
  fileName     = "types.ts"
  enumFileName = "enums.ts"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Auth models — managed by Better Auth (https://www.better-auth.com/)

model User {
  id             String             @id
  name           String
  email          String             @unique
  emailVerified  Boolean            @default(false)
  image          String?
  approvalStatus UserApprovalStatus @default(PENDING)
  role           UserRole           @default(USER)
  accounts       Account[]
  sessions       Session[]
  books          Book[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@map("user")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Application models

enum BookStatus {
  IN_PROGRESS
  COMPLETE
  ARCHIVED
}

enum InterviewStatus {
  ACTIVE
  PAUSED
  COMPLETE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum InsightType {
  ENTITY
  EVENT
  EMOTION
  DETAIL
}

enum StoryStatus {
  DRAFT
  REVIEWED
  FINAL
}

enum StorySectionStatus {
  GENERATING
  DRAFT
  FINAL
}

enum UserApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

model Question {
  id             String         @id @default(cuid())
  category       String
  prompt         String
  orderIndex     Int
  bookQuestions  BookQuestion[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("question")
}

model Book {
  id            String         @id @default(cuid())
  userId        String
  title         String
  coreMemory    String?
  status        BookStatus     @default(IN_PROGRESS)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookQuestions BookQuestion[]
  interviews    Interview[]
  insights      Insight[]
  stories       Story[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId])
  @@map("book")
}

model BookQuestion {
  id          String     @id @default(cuid())
  bookId      String
  questionId  String
  orderIndex  Int
  interviewId String?    @unique
  book        Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  question    Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  interview   Interview? @relation(fields: [interviewId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([bookId, questionId])
  @@index([bookId])
  @@index([questionId])
  @@map("book_question")
}

model Interview {
  id           String             @id @default(cuid())
  bookId       String
  topic        String
  status       InterviewStatus    @default(ACTIVE)
  completedAt  DateTime?
  book         Book               @relation(fields: [bookId], references: [id], onDelete: Cascade)
  bookQuestion BookQuestion?
  messages     Message[]
  insights     Insight[]
  summaries    InterviewSummary[]
  stories      Story[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([bookId])
  @@map("interview")
}

model Message {
  id          String      @id @default(cuid())
  interviewId String
  role        MessageRole
  content     String
  hidden      Boolean     @default(false)
  interview   Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())

  @@index([interviewId])
  @@map("message")
}

model Insight {
  id          String      @id @default(cuid())
  bookId      String
  interviewId String
  type        InsightType
  content     String
  explored    Boolean     @default(false)
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  interview   Interview   @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([bookId])
  @@index([interviewId])
  @@map("insight")
}

model InterviewSummary {
  id              String            @id @default(cuid())
  interviewId     String
  parentSummaryId String?           @unique
  content         String
  messageCount    Int
  interview       Interview         @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  parentSummary   InterviewSummary? @relation("SummaryChain", fields: [parentSummaryId], references: [id])
  childSummary    InterviewSummary? @relation("SummaryChain")
  createdAt       DateTime          @default(now())

  @@index([interviewId])
  @@index([parentSummaryId])
  @@map("interview_summary")
}

model Story {
  id          String         @id @default(cuid())
  bookId      String
  interviewId String
  title       String
  prose       String?
  orderIndex  Int
  status      StoryStatus    @default(DRAFT)
  book        Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)
  interview   Interview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  sections    StorySection[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([bookId])
  @@index([interviewId])
  @@map("story")
}

model StorySection {
  id         String             @id @default(cuid())
  storyId    String
  orderIndex Int
  content    String
  status     StorySectionStatus @default(GENERATING)
  story      Story              @relation(fields: [storyId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([storyId])
  @@map("story_section")
}
