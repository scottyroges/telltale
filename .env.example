# Database (local: Docker Compose; production: Neon)
DATABASE_URL="postgresql://telltale:telltale@localhost:5432/telltale"
DIRECT_URL="postgresql://telltale:telltale@localhost:5432/telltale"

# Auth (Better Auth)
# BETTER_AUTH_SECRET: required in all environments — generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL: set for production only — preview deploys auto-detect via VERCEL_URL
BETTER_AUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Resend)
EMAIL_FROM="noreply@telltale.app"
RESEND_API_KEY=""

# AI
ANTHROPIC_API_KEY=""

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="telltale-audio"

# Transcription (Phase 2)
DEEPGRAM_API_KEY=""

# TTS (Phase 3)
ELEVENLABS_API_KEY=""
